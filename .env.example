PROJECT_NAME="Savage Fortune Teller API"
API_V1_PREFIX="/api/v1"

# Comma-separated list. Use your frontend URL in production.
# Example: BACKEND_CORS_ORIGINS="https://your-domain.com,https://www.your-domain.com"
BACKEND_CORS_ORIGINS="*"

# Optional when latitude, longitude, and timezone are supplied by the client.
# Required if the backend should geocode city/country input itself.
GEONAMES_USERNAME="YOUR_GEONAMES_USERNAME"

# Firestore database used for share links.
FIRESTORE_DATABASE="sft-db"
FIRESTORE_SHARES_COLLECTION="shares"

# Optional. When set, POST /shares returns a full share_url instead of only /r/{id}.
# Example: PUBLIC_APP_URL="https://your-domain.com"
PUBLIC_APP_URL=""
